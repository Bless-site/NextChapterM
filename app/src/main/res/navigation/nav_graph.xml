<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/registrationFragment">

    <fragment
        android:id="@+id/registrationFragment"
        android:name="com.nextchapter.app.ui.auth.RegistrationFragment"
        android:label="Register"
        tools:layout="@layout/fragment_registration">
        <action
            android:id="@+id/action_registration_to_home"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/registrationFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.nextchapter.app.ui.home.HomeFragment"
        android:label="Home"
        tools:layout="@layout/fragment_home">
        <action
            android:id="@+id/action_home_to_detail"
            app:destination="@id/bookDetailFragment" />
    </fragment>

    <fragment
        android:id="@+id/searchFragment"
        android:name="com.nextchapter.app.ui.search.SearchFragment"
        android:label="Search"
        tools:layout="@layout/fragment_search">
        <action
            android:id="@+id/action_search_to_detail"
            app:destination="@id/bookDetailFragment" />
    </fragment>

    <fragment
        android:id="@+id/sellFragment"
        android:name="com.nextchapter.app.ui.sell.SellFragment"
        android:label="Sell"
        tools:layout="@layout/fragment_sell" />

    <fragment
        android:id="@+id/bookDetailFragment"
        android:name="com.nextchapter.app.ui.detail.BookDetailFragment"
        android:label="Book Details"
        tools:layout="@layout/fragment_book_detail">
        <argument
            android:name="bookId"
            app:argType="integer" />
        <action
            android:id="@+id/action_detail_to_inquiry"
            app:destination="@id/inquiryFragment" />
    </fragment>

    <fragment
        android:id="@+id/inquiryFragment"
        android:name="com.nextchapter.app.ui.inquiry.InquiryFragment"
        android:label="Send Inquiry"
        tools:layout="@layout/fragment_inquiry">
        <argument
            android:name="bookId"
            app:argType="integer" />
    </fragment>

</navigation>