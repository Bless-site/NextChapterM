<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/warm_ivory">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/african_green"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/btn_back"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="← Back"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:paddingEnd="12dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Book Details"
                    android:gravity="center"
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/btn_save"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="♡"
                    android:textColor="@color/white"
                    android:textSize="20sp" />
            </LinearLayout>
            <View android:layout_width="match_parent" android:layout_height="4dp" android:background="@color/kente_gold" />
        </LinearLayout>

        <!-- Book cover image -->
        <ImageView
            android:id="@+id/iv_book_cover_detail"
            android:layout_width="200dp"
            android:layout_height="160dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="16dp"
            android:background="@color/terracotta"
            android:contentDescription="Book cover"
            android:scaleType="centerCrop" />

        <!-- Book info -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tv_detail_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:textColor="@color/dark_charcoal"
                android:textSize="16sp"
                android:textStyle="bold"
                android:gravity="center" />

            <TextView
                android:id="@+id/tv_detail_author"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="4dp"
                android:textColor="@color/mid_grey"
                android:textSize="12sp"
                android:gravity="center" />

            <!-- Badges row -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tv_detail_course_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@color/african_green"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:textColor="@color/white"
                    android:textSize="11sp"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/tv_detail_condition_badge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@color/soft_sage"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:textColor="@color/african_green"
                    android:textSize="11sp"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/tv_detail_price"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@color/kente_gold"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:textColor="@color/white"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Separator -->
            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/card_border" android:layout_marginTop="16dp" android:layout_marginBottom="12dp" />

            <!-- Seller info -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:id="@+id/tv_seller_avatar"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@color/african_green"
                    android:gravity="center"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginEnd="12dp" />

                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical">
                    <TextView android:id="@+id/tv_seller_name" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/dark_charcoal" android:textSize="13sp" android:textStyle="bold" />
                    <TextView android:id="@+id/tv_seller_location" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/mid_grey" android:textSize="11sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Details -->
            <TextView android:id="@+id/tv_label_posted" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="@color/dark_charcoal" android:textSize="12sp" android:layout_marginBottom="4dp" />
            <TextView android:id="@+id/tv_label_location" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="@color/dark_charcoal" android:textSize="12sp" android:layout_marginBottom="12dp" />

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Description" android:textColor="@color/dark_charcoal" android:textSize="13sp" android:textStyle="bold" android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tv_detail_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/form_field_bg"
                android:padding="12dp"
                android:textColor="@color/dark_charcoal"
                android:textSize="12sp"
                android:layout_marginBottom="20dp" />

            <!-- Action buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_send_inquiry"
                    style="@style/PrimaryButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="Send Inquiry" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_save_listing"
                    style="@style/SecondaryButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Save Listing" />
            </LinearLayout>
        </LinearLayout>

        <!-- Bottom kente strip -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="8dp" android:orientation="horizontal">
            <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="@color/kente_gold" />
            <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="@color/terracotta" />
            <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="@color/kente_gold" />
            <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="@color/african_green" />
            <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="@color/terracotta" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>